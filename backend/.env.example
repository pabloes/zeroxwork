# ===========================================
# ZEROxWORK Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in real values.
# The app will NOT start if required secrets are missing.

# --- Database ---
DATABASE_URL="postgresql://postgres:password@localhost:5432/zeroxwork"

# --- Required Secrets (app fails to start without these) ---
JWT_SECRET=
SESSION_SECRET=
ADMIN_COOKIE_PASSWORD=

# --- SMTP (email verification) ---
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# --- External APIs ---
VIRUS_TOTAL_KEY=
DEEPL_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=.vision-api-credential.json

# --- ClamAV (optional, server starts without it) ---
CLAM_AV_HOST=
CLAM_AV_PORT=
CLAM_AV_SOCKET_FILE=
